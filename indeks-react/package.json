{
    "name": "@sb1/indeks-react",
    "version": "0.2.21",
    "type": "module",
    "description": "React components for Indeks design system",
    "homepage": "https://design.sparebank1.no",
    "repository": {
        "type": "git",
        "url": "https://github.com/SpareBank1/indeks",
        "directory": "indeks-react"
    },
    "bugs": {
        "url": "https://github.com/SpareBank1/indeks/issues"
    },
    "keywords": [
        "indeks",
        "design-system",
        "react",
        "components",
        "sparebank1",
        "ui"
    ],
    "main": "dist/main.js",
    "types": "dist/main.d.ts",
    "exports": {
        ".": {
            "types": "./dist/main.d.ts",
            "import": "./dist/main.js"
        }
    },
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -b ./tsconfig.json && vite build",
        "prepublishOnly": "pnpm run build",
        "lint": "eslint .",
        "preview": "vite preview",
        "update-packages": "npx npm-check-updates -i --format group",
        "create-component": "plop component",
        "test": "vitest"
    },
    "author": "",
    "license": "MIT",
    "dependencies": {
        "clsx": "^2.1.1"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/browser": "^4.1.2",
        "eslint-plugin-react-refresh": "^0.5.2",
        "jsdom": "^29.0.1",
        "plop": "^4.0.5",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "typescript": "~5.9.3",
        "vite": "^8.0.3",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.2",
        "vitest-browser-react": "^2.2.0"
    }
}
