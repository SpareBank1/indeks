{
    "name": "@sb1/indeks-eksempel",
    "private": true,
    "license": "MIT",
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "npm run cp:themes && vite --open",
        "build": "tsc --noEmit && npm run cp:themes && vite build",
        "cp:themes": "mkdir -p ./public/themes && cp -r ../indeks-tokens/.build/css/themes/* ./public/themes",
        "lint": "eslint .",
        "update-packages": "npx npm-check-updates -i --format group",
        "preview": "vite preview"
    },
    "dependencies": {
        "@sb1/indeks-react": "workspace:*",
        "clsx": "^2.1.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router-dom": "^7.13.1"
    },
    "devDependencies": {
        "@types/node": "^24.12.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-router-dom": "^5.3.3",
        "@vitejs/plugin-react": "^5.1.4",
        "debug": "4.4.3",
        "eslint": "^9.39.3",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "typescript": "~5.9.3",
        "vite": "^7.3.1"
    }
}
